# ============================================================
# TEMPLATE - JANGAN ISI CREDENTIAL ASLI DI FILE INI!
# Untuk credential asli, pakai file secrets.toml (tidak di-push)
# ============================================================

[auth]
username = "GANTI_USERNAME"
password = "GANTI_PASSWORD"

[rajaongkir]
api_key = "GANTI_API_KEY"

[gsheets]
spreadsheet_id = "GANTI_SPREADSHEET_ID"

[gcp_service_account]
type = "service_account"
project_id = "GANTI"
private_key_id = "GANTI"
private_key = "GANTI"
client_email = "GANTI"
client_id = "GANTI"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "GANTI"
universe_domain = "googleapis.com"
